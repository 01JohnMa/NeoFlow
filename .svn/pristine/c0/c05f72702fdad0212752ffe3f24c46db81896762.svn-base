[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/01JohnMa/sj_ocr.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "2026-01-19-0jbh"]
	remote = origin
	merge = refs/heads/2026-01-19-0jbh
[branch "0r"]
	vscode-merge-base = origin/2026-01-19-0jbh
[branch "develop"]
	remote = origin
	merge = refs/heads/develop
	vscode-merge-base = origin/main
[branch "main"]
	remote = origin
	merge = refs/heads/master
	vscode-merge-base = origin/master
[branch "master"]
	remote = origin
	merge = refs/heads/master
	vscode-merge-base = origin/master
[branch "feat-ocr-batch"]
	vscode-merge-base = origin/master
	remote = origin
	merge = refs/heads/feat-ocr-batch
