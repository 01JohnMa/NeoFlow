############
# Secrets - 安全密钥
############

# PostgreSQL 数据库密�?(请更换为强密�?
POSTGRES_PASSWORD=123456

# JWT 密钥 (至少32位字符)
# 此值必须与 ANON_KEY/SERVICE_ROLE_KEY 签名使用的 secret 一致
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# API Keys
# 可使�?https://supabase.com/docs/guides/self-hosting#api-keys 生成
# 以下为开发测试用的默认密�?
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

############
# Database - 数据库配�?
############
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres

############
# API - 接口配置
############
API_EXTERNAL_URL=http://10.10.80.37:8080
SITE_URL=http://10.10.80.37:8080
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

############
# API 网关端口
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# Studio - 管理界面配置
############
STUDIO_PORT=3001
SUPABASE_PUBLIC_URL=http://10.10.80.37:8080
STUDIO_DEFAULT_ORGANIZATION=OCR System
STUDIO_DEFAULT_PROJECT=OCR Document Processor

############
# Email - 邮件配置 (可�?
############
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=

