# ============================================================
# OCR文档智能处理系统 - 环境变量配置模板
# ============================================================
# 使用方式：复制此文件为 .env 并填入实际配置
# copy env.example.txt .env  (Windows)
# cp env.example.txt .env    (Linux/Mac)
# ============================================================

# ============ 应用基础配置 ============
APP_NAME=OCR-Document-Processor
DEBUG=true
HOST=0.0.0.0
PORT=8080

# ============ 安全配置 ============
SECRET_KEY=sj-ocr-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============ Supabase本地配置 ============
# 使用本地部署的Supabase
SUPABASE_URL=http://localhost:8000
# 以下密钥需与 supabase/.env 中的配置保持一致
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# PostgreSQL直连 (可选，用于数据库迁移)
DATABASE_URL=postgresql://postgres:123456@localhost:5432/postgres

# ============ LLM配置 (DeepSeek) ============
LLM_API_KEY=sk-71b00796558d4249b09f163180d51986
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_ID=deepseek-chat
LLM_TEMPERATURE=0.7

# ============ OCR模型配置 ============
# 模型路径（相对于项目根目录）
OCR_DET_MODEL_PATH=./model/PP-OCRv5_server_det_infer
OCR_REC_MODEL_PATH=./model/PP-OCRv5_server_rec_infer
OCR_ORI_MODEL_PATH=./model/PP-LCNet_x1_0_textline_ori_infer
OCR_DOC_MODEL_PATH=./model/PP-LCNet_x1_0_doc_ori_infer

# ============ 文件存储配置 ============
UPLOAD_FOLDER=./uploads
MAX_FILE_SIZE=20971520
ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tiff,.bmp

# ============ 日志配置 ============
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# ============ CORS配置 ============
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080
ALLOWED_HOSTS=localhost,127.0.0.1

# ============ 飞书配置 ============
# 在飞书开发者后台创建应用获取
FEISHU_APP_ID=cli_a9de210755f85bc0
FEISHU_APP_SECRET=MpQ0xYYDSfRspAzt5l0RvdYxtiXUsIw1
# 多维表格配置（从多维表格URL中获取）
FEISHU_BITABLE_APP_TOKEN=WNYMbxfiIaY7rasaO44caKxznxd
FEISHU_BITABLE_TABLE_ID=tblu4KCbSRBhlZr7
# 是否启用飞书推送（填写完上述配置后改为 true）
FEISHU_PUSH_ENABLED=true

