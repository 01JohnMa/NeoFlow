# ============================================================
# NeoFlow / OCR Agentic System - 生产环境（Docker Compose）配置
# ============================================================
# 由于编辑器会过滤以 .env* 命名的文件，这里用 env.prod.example.txt 提供模板。
#
# 使用方式（二选一）：
# 1) 直接用 --env-file 指定：
#    docker compose --env-file env.prod.example.txt -f supabase/docker-compose.yml -f docker-compose.prod.yml up -d
# 2) 复制为 .env（仓库根目录）：
#    copy env.prod.example.txt .env
#    docker compose -f supabase/docker-compose.yml -f docker-compose.prod.yml up -d
#
# 说明：
# - 本文件的 Supabase 变量名与 supabase/docker-compose.yml 保持一致（ANON_KEY / SERVICE_ROLE_KEY / JWT_SECRET / POSTGRES_PASSWORD）。
# - 后端容器会通过 docker-compose.prod.yml 将 ANON_KEY/SERVICE_ROLE_KEY 注入为 SUPABASE_*（无需重复维护两套 key）。
# ============================================================

# ============ 基础配置 ============
APP_NAME=NeoFlow
DEBUG=false
HOST=0.0.0.0
PORT=8080

# ============ Supabase（必须配置，且前后端需一致） ============
POSTGRES_PASSWORD=123456
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Supabase 对外入口（内网访问时需改为本机 IP，与 CORS/SITE_URL 一致）
# 若通过 ingress 统一入口访问，端口用 8080；若直连 Kong 用 8000
SUPABASE_PUBLIC_URL=http://10.10.80.37:8080
API_EXTERNAL_URL=http://10.10.80.37:8080
SITE_URL=http://10.10.80.37:8080

# ============ 后端（可选，按需填写） ============
# LLM（不需要可留空；需要则填写并确保后端容器能访问对应网关）
LLM_API_KEY=sk-71b00796558d4249b09f163180d51986
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL_ID=deepseek-chat
LLM_TEMPERATURE=0.7

# 飞书（不需要可留空或禁用；需要则填写并启用）
FEISHU_APP_ID=cli_a9de210755f85bc0
FEISHU_APP_SECRET=MpQ0xYYDSfRspAzt5l0RvdYxtiXUsIw1
FEISHU_BITABLE_APP_TOKEN=WNYMbxfiIaY7rasaO44caKxznxd
FEISHU_BITABLE_TABLE_ID=tblu4KCbSRBhlZr7
FEISHU_PUSH_ENABLED=true

# CORS / Hosts（内网访问时需包含本机 IP）
CORS_ORIGINS=http://localhost,http://10.10.80.37,http://10.10.80.37:8080
ALLOWED_HOSTS=localhost,127.0.0.1,10.10.80.37

